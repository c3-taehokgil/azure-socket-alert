# Copy to terraform.tfvars and fill in. Do not commit terraform.tfvars if it contains secrets.

subscription_id = "00000000-0000-0000-0000-000000000000"
location        = "eastus"
environment     = "prod"
project_name    = "socket-alert"

# Socket.dev (required)
socket_org_slug = "c3-ai"

# Function app settings (D4 / D9 / D10)
mail_sender_upn   = "socket-alerts@c3.ai"
mail_to_addresses = "dependency-security@c3.ai"
min_severity      = "low"

tags = {
  project     = "socket-alert"
  environment = "prod"
  managed_by  = "terraform"
  cost_center = ""
  owner       = "platform-engineering"
}
